<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PileBreak.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PileBreak.Views"
    Title="PileBreak">

    <TabBar>
        <!-- 積み（メイン画面） -->
        <Tab Title="Pile" Icon="pile_icon.png">
            <ShellContent 
            Title="すべて"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        </Tab>

        <!-- 消化済み（履歴画面） -->
        <Tab Title="History" Icon="history_icon.png">
            <ShellContent 
            Title="消化済み"
            ContentTemplate="{DataTemplate local:HistoryPage}" />
        </Tab>

        <!-- 設定 -->
        <Tab Title="Settings" Icon="settings_icon.png">
            <ShellContent 
            Title="設定"
            ContentTemplate="{DataTemplate local:SettingPage}" />
        </Tab>
    </TabBar>



</Shell>
